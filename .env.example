# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scraper runtime
BACKEND_URL=http://localhost:8000
BACKEND_API_KEY=change-me
IDEALISTA_SOURCE_ID=00000000-0000-0000-0000-000000000002
IDEALISTA_HTML_PATH=
IDEALISTA_SEARCH_URL=
IDEALISTA_SEARCH_HTML=
PROFESSIONECASA_SOURCE_ID=00000000-0000-0000-0000-000000000003
PROFESSIONECASA_HTML_PATH=
