SCRAPER_TIMEOUT_SECONDS=20
SCRAPER_MAX_RETRIES=3
SCRAPER_CONCURRENCY_PER_SOURCE=2
SCRAPER_REQUEST_DELAY_MIN_MS=350
SCRAPER_REQUEST_DELAY_MAX_MS=1200
SCRAPER_MISSING_THRESHOLD=2
